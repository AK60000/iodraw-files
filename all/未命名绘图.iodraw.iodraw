        <mxCell id="DzJzp5CRhRRx_YrPkgzO-3" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="470" width="520" height="290" as="geometry" />
        </mxCell>
        <mxCell id="DzJzp5CRhRRx_YrPkgzO-4" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
